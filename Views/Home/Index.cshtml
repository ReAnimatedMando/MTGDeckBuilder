@{
    ViewData["Title"] = "Home";
    ViewData["IsHomePage"] = true;
}

<section class="home-hero home-hero-home mb-5">
    <div class="home-hero-overlay"></div>
    <div class="row align-items-center g-4 position-relative">
        <div class="col-lg-7">
            <div class="home-kicker mb-3">Magic: The Gathering Collection & Deck Building</div>
            <h1 class="home-title mb-3">
                Build smarter decks from the cards you actually own.
            </h1>
            <p class="home-subtitle mb-4">
                Search cards, track your collection, and build smarter decks with a workflow designed for serious gaming.
            </p>

            <div class="d-flex flex-wrap gap-3 mb-4">
                <a asp-controller="Decks" asp-action="Create" class="btn app-btn-primary btn-lg hero-cta hero-cta-primary">
                    <span>Start a New Deck</span>
                </a>
                <a asp-controller="Cards" asp-action="Index" class="btn btn-outline-light btn-lg app-btn-outline hero-cta hero-cta-outline">
                    <span>Explore Cards</span>
                </a>
            </div>

            <div class="home-feature-chips">
                <span class="home-chip">Deck Building</span>
                <span class="home-chip">Owned Card Tracking</span>
                <span class="home-chip">Search & Import</span>
                <span class="home-chip">Collection Insights</span>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="home-hero-panel">
                <div class="home-panel-label">What you can do</div>

                <div class="home-panel-item">
                    <div class="home-panel-icon mana-white">W</div>
                    <div>
                        <div class="home-panel-title">Track your collection</div>
                        <div class="home-panel-text">Keep your owned cards organized by quantity, color, and type.</div>
                    </div>
                </div>

                <div class="home-panel-item">
                    <div class="home-panel-icon mana-blue">U</div>
                    <div>
                        <div class="home-panel-title">Search and discover</div>
                        <div class="home-panel-text">Browse your local card data and expand your collection intelligently.</div>
                    </div>
                </div>

                <div class="home-panel-item">
                    <div class="home-panel-icon mana-black">B</div>
                    <div>
                        <div class="home-panel-title">Review your options</div>
                        <div class="home-panel-text">See what your collection supports before committing to your next brew.</div>
                    </div>
                </div>

                <div class="home-panel-item">
                    <div class="home-panel-icon mana-red">R</div>
                    <div>
                        <div class="home-panel-title">Brew with purpose</div>
                        <div class="home-panel-text">Build around themes, colors, and the cards you already have on hand.</div>
                    </div>
                </div>

                <div class="home-panel-item">
                    <div class="home-panel-icon mana-green">G</div>
                    <div>
                        <div class="home-panel-title">Refine over time</div>
                        <div class="home-panel-text">Use deck pages and collection views to iterate like a real deck lab.</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="row g-4 mb-5">
    <div class="col-md-4">
        <div class="feature-card h-100">
            <div class="feature-card-kicker">Collection</div>
            <h2 class="feature-card-title">Own what you track</h2>
            <p class="feature-card-text">
               Keep accurate counts of your collection and update quantities quickly while you build.
            </p>
            <a asp-controller="OwnedCards" asp-action="Index" class="feature-card-link">Go to Owned Cards</a>
        </div>
    </div>

    <div class="col-md-4">
        <div class="feature-card h-100">
            <div class="feature-card-kicker">Decks</div>
            <h2 class="feature-card-title">Build with intent</h2>
            <p class="feature-card-text">
                Create decks around themes and color identity, then refine them as your collection grows.
            </p>
            <a asp-controller="Decks" asp-action="Index" class="feature-card-link">View Decks</a>
        </div>
    </div>

    <div class="col-md-4">
        <div class="feature-card h-100">
            <div class="feature-card-kicker">Search</div>
            <h2 class="feature-card-title">Find the right card fast</h2>
            <p class="feature-card-text">
                Search your card database, preview art, and jump straight into details or collection actions.
            </p>
            <a asp-controller="Cards" asp-action="Index" class="feature-card-link">Browse Cards</a>
        </div>
    </div>
</section>

<section class="home-bottom-banner">
    <div class="row align-items-center g-3">
        <div class="col-lg-8">
            <div class="home-bottom-kicker">Ready to brew?</div>
            <h2 class="mb-2">Your workshop is live.</h2>
            <p class="mb-0 text-light-emphasis">
                Start with your collection, browse cards, or jump directly into a fresh deck build.
            </p>
        </div>
        <div class="col-lg-4 text-lg-end">
            <a asp-controller="Decks" asp-action="Create" class="btn app-btn-primary btn-lg hero-cta hero-cta-primary">
                Create a Deck
            </a>
        </div>
    </div>
</section>