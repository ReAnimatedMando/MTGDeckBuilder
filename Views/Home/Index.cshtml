@{
    ViewData["Title"] = "Home";
}

<div class="py-4">
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-4 p-lg-5">
            <div class="row align-items-center g-4">
                <div class="col-lg-8">
                    <h1 class="display-5 fw-bold mb-3">MTG Deck Builder</h1>
                    <p class="lead mb-3">
                        Build decks, track your collection, and see how close you are to completing each list.
                    </p>
                    <p class="text-muted mb-4">
                        Search cards, manage owned copies, analyze deck completion, estimate value, and import decklists all in one place.
                    </p>

                    <div class="d-flex flex-wrap gap-2">
                        <a class="btn btn-primary" asp-controller="Decks" asp-action="Index">View Decks</a>
                        <a class="btn btn-outline-primary" asp-controller="Cards" asp-action="Index">Browse Cards</a>
                        <a class="btn btn-outline-secondary" asp-controller="OwnedCards" asp-action="Index">Owned Cards</a>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="card bg-light border-0">
                        <div class="card-body">
                            <h2 class="h5 mb-3">What you can do</h2>
                            <ul class="mb-0 ps-3">
                                <li class="mb-2">Search and view your card database</li>
                                <li class="mb-2">Track owned quantities and collection value</li>
                                <li class="mb-2">Build main decks and sideboards</li>
                                <li class="mb-2">Import decklists from text or URL</li>
                                <li>Measure buildability and missing cards</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h2 class="h5">Cards</h2>
                    <p class="text-muted mb-3">
                        Browse your card database and search by name, type, mana cost, or color identity.
                    </p>
                    <a asp-controller="Cards" asp-action="Index" class="btn btn-sm btn-outline-primary">Open Cards</a>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h2 class="h5">Owned Cards</h2>
                    <p class="text-muted mb-3">
                        Keep track of the cards you own and update collection quantities anytime.
                    </p>
                    <a asp-controller="OwnedCards" asp-action="Index" class="btn btn-sm btn-outline-primary">Open Collection</a>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h2 class="h5">Decks</h2>
                    <p class="text-muted mb-3">
                        Build and manage decks, then check completion, value, and missing cards.
                    </p>
                    <a asp-controller="Decks" asp-action="Index" class="btn btn-sm btn-outline-primary">Open Decks</a>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h2 class="h5">Collection Stats</h2>
                    <p class="text-muted mb-3">
                        Analyze totals, top owned cards, and color and type distribution.
                    </p>
                    <a asp-controller="Collection" asp-action="Stats" class="btn btn-sm btn-outline-primary">Open Stats</a>
                </div>
            </div>
        </div>
    </div>
</div>