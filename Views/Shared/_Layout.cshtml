<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MTGDeckBuilder</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MTGDeckBuilder.styles.css" asp-append-version="true" />
</head>
<body class="bg-light">
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm">
            <div class="container-xl py-2">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">
                    MTGDeckBuilder
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
                        aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav align-items-lg-center gap-lg-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Cards" asp-action="Index">Cards</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="OwnedCards" asp-action="Index">Owned Cards</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Collection" asp-action="Stats">Collection Stats</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Decks" asp-action="Index">Decks</a>
                        </li>
                    </ul>

                    <div class="ms-auto mt-3 mt-lg-0">
                        <a class="btn btn-primary" asp-controller="Decks" asp-action="Create">New Deck</a>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-xl py-4">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top bg-white text-muted mt-4">
        <div class="container-xl py-3 small">
            &copy; 2026 - MTGDeckBuilder -
            <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
