@model IEnumerable<Card>
@using MTGDeckBuilder.Models

@{
    ViewData["Title"] = "Cards";

    var q = Context.Request.Query["q"].ToString();
    var hasQuery = !string.IsNullOrWhiteSpace(q);
    var hasResults = Model != null && Model.Any();
    var resultCount = Model?.Count() ?? 0;
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show app-alert mb-4" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="page-header d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-3">
    <div>
        <div class="page-eyebrow">Card Library</div>
        <h1 class="page-title">@(hasQuery ? "Search Results" : "Cards")</h1>
        <p class="page-subtitle">
            Search by card name, type, mana cost, or color identity.
        </p>
    </div>

    <form asp-action="RefreshPrices" method="post" class="mb-0">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-outline-danger app-btn-utility">
            Refresh All Card Prices
        </button>
    </form>
</div>

<div class="filter-card mb-4">
    <div class="card-body">
        <form method="get">
            <div class="row g-2 align-items-center">
                <div class="col-lg">
                    <input name="q"
                           value="@q"
                           class="form-control"
                           placeholder="Search card name, type, mana cost, or color identity..." />
                </div>
                <div class="col-auto">
                    <button class="btn btn-primary app-btn-search" type="submit">Search</button>
                </div>

                @if (hasQuery)
                {
                    <div class="col-auto">
                        <a class="btn btn-outline-secondary" asp-action="Index">Clear</a>
                    </div>
                }
            </div>
        </form>
    </div>
</div>

@if (!hasQuery)
{
    <div class="empty-state">
        <div class="empty-state-title">Start your search</div>
        <p class="empty-state-text">
            Search for a card by name, type, mana cost, or color identity
        </p>
    </div>
}
else if (!hasResults)
{
    <div class="empty-state">
        <div class="empty-state-title">No cards found</div>
        <p class="empty-state-text">
            No results matched "<strong>@q</strong>".
        </p>
    </div>
}
else
{
    <div class="section-card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>Found @resultCount card@(resultCount == 1 ? "" : "s")</span>
            <span class="text-muted small">Showing up to 200 results</span>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive table-wrap">
                <table class="table table-hover align-middle app-table mb-0">
                    <thead>
                        <tr>
                            <th style="width: 100px;">Image</th>
                            <th>Name</th>
                            <th>Mana Cost</th>
                            <th>Type</th>
                            <th>Color Identity</th>
                            <th style="width: 180px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var card in Model)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(card.ImageUrl))
                                {
                                    <img src="@card.ImageUrl"
                                         alt="@card.Name"
                                         width="80"
                                         class="img-fluid rounded shadow-sm card-preview-trigger"
                                         data-image-url="@card.ImageUrl"
                                         data-card-name="@card.Name" />
                                }
                                else
                                {
                                    <span class="text-muted small">No Image</span>
                                }
                            </td>

                            <td class="card-name-cell">
                                <a asp-action="Details"
                                   asp-route-id="@card.Id"
                                   class="app-link card-name-link card-preview-trigger"
                                   data-image-url="@card.ImageUrl"
                                   data-card-name="@card.Name">
                                    @card.Name
                                </a>
                            </td>

                            <td>
                                <span class="text-nowrap">@(string.IsNullOrWhiteSpace(card.ManaCost) ? "-" : card.ManaCost)</span>
                            </td>

                            <td>
                                @(string.IsNullOrWhiteSpace(card.TypeLine) ? "-" : card.TypeLine)
                            </td>

                            <td>
                                @if (string.IsNullOrWhiteSpace(card.ColorIdentity))
                                {
                                    <span class="text-muted">-</span>
                                }
                                else
                                {
                                    <span class="card-color-identity">@card.ColorIdentity</span>
                                }
                            </td>

                            <td>
                                <form asp-controller="Decks"
                                      asp-action="AddToOwned"
                                      method="post"
                                      class="add-owned-form">
                                    @Html.AntiForgeryToken()

                                    <input type="hidden" name="cardId" value="@card.Id" />

                                    <input type="number"
                                           name="quantity"
                                           value="1"
                                           min="1"
                                           class="form-control form-control-sm add-owned-qty" />

                                    <button type="submit" class="btn btn-sm btn-outline-warning add-owned-btn">
                                        + Owned
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
