@model IEnumerable<Card>

<h1>All Cards</h1>

<form method="get" class="mb-3">
    <div class="input-group">
        <input name="q" value="@Context.Request.Query["q"]" class="form-control" placeholder="Search card name, type, mana cost, or color identity..." />
        <button class="btn btn-primary" type="submit">Search</button>
        @if (!string.IsNullOrWhiteSpace(Context.Request.Query["q"]))
        {
            <a class="btn btn-outline-secondary" asp-action="Index">Clear</a>
        }
    </div>
</form>

<table class="table table-striped align-middle">
    <thead>
        <tr>
            <th>Image</th>
            <th>Name</th>
            <th>Mana Cost</th>
            <th>Type</th>
            <th>Color Identity</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var card in Model)
        {
            <tr>
                <td style="width: 90px;">
                    @if (!string.IsNullOrEmpty(card.ImageUrl))
                    {
                        <img src="@card.ImageUrl" width="80" class="img-fluid rounded" alt="@card.Name" />
                    }
                    else
                    {
                        <span class="text-muted">No Image</span>
                    }
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@card.Id">@card.Name</a>
                </td>
                <td>@card.ManaCost</td>
                <td>@card.TypeLine</td>
                <td>@card.ColorIdentity</td>
            </tr>
        }
    </tbody>
</table>
