@model MTGDeckBuilder.Models.ViewModels.BuildDeckRequestViewModel

@{
    ViewData["Title"] = "Build Deck";
}

<h1 class="mb-3">Build Deck from Owned Cards</h1>

<div class="text-muted mb-4">
    Generate a deck from 60 to 100 cards using your owned collection, selected colors, and a simple balance template.
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Build" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Theme" class="form-label"></label>
                <input asp-for="Theme" class="form-control" placeholder="Examples: Burn, Lifegain, Zombies, Artifacts" />
                <div class="form-text">
                    Examples: Burn, Artifacts, Zombies, Angels, Aggro, Control, Lifegain
                </div>
                <span asp-validation-for="Theme" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="DeckSize" class="form-label"></label>
                <input asp-for="DeckSize" class="form-control" min="60" max="100" />
                <div class="form-text">Choose a deck size between 60 and 100 cards.</div>
                <span asp-validation-for="DeckSize" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Colors</label>
                <div class="row g-2">
                    <div class="col-sm-6 col-lg-4">
                        <div class="form-check">
                            <input asp-for="UseWhite" class="form-check-input" />
                            <label asp-for="UseWhite" class="form-check-label"></label>
                        </div>
                    </div>
                    <div class="col-sm-6 col-lg-4">
                        <div class="form-check">
                            <input asp-for="UseBlue" class="form-check-input" />
                            <label asp-for="UseBlue" class="form-check-label"></label>
                        </div>
                    </div>
                    <div class="col-sm-6 col-lg-4">
                        <div class="form-check">
                            <input asp-for="UseBlack" class="form-check-input" />
                            <label asp-for="UseBlack" class="form-check-label"></label>
                        </div>
                    </div>
                    <div class="col-sm-6 col-lg-4">
                        <div class="form-check">
                            <input asp-for="UseRed" class="form-check-input" />
                            <label asp-for="UseRed" class="form-check-label"></label>
                        </div>
                    </div>
                    <div class="col-sm-6 col-lg-4">
                        <div class="form-check">
                            <input asp-for="UseGreen" class="form-check-input" />
                            <label asp-for="UseGreen" class="form-check-label"></label>
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Build Deck</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
