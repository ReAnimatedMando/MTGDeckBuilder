@model IEnumerable<MTGDeckBuilder.Models.ViewModels.DeckBuildabilityViewModel>

@{
    ViewData["Title"] = "Decks";

    var currentSort = ViewBag.CurrentSort as string;
    var currentStatus = ViewBag.CurrentStatus as string;

    var totalDecks = Model.Count();
    var buildableDecks = Model.Count(d => d.Status == "Buildable");
    var avgCompletion = totalDecks == 0 ? 0 : (int)Math.Round(Model.Average(d => d.CompletionPercent));
}

<div class="page-header d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-3">
    <div>
        <div class="page-eyebrow">Deck Workshop</div>
        <h1 class="page-title">Decks</h1>
        <p class="page-subtitle">
            Track completion, missing cards, value, and buildability across your deck collection.
        </p>
    </div>

    <div class="d-flex flex-column flex-sm-row gap-2">
        <a class="btn app-btn-primary" asp-action="Create">Create New Deck</a>
        <a class="btn btn-outline-success app-btn-utility" asp-action="Build">Build Deck</a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="stat-tile h-100">
            <div class="stat-tile-label">Total Decks</div>
            <div class="stat-tile-value">@totalDecks</div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="stat-tile h-100">
            <div class="stat-tile-label">Buildable Decks</div>
            <div class="stat-tile-value">@buildableDecks</div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="stat-tile h-100">
            <div class="stat-tile-label">Average Completion</div>
            <div class="stat-tile-value">@avgCompletion%</div>
        </div>
    </div>
</div>

<div class="filter-card mb-4">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-center">
            <div class="col-md-4 col-lg-3">
                <select name="sort" class="form-select">
                    <option value="" selected="@(string.IsNullOrWhiteSpace(currentSort))">Most Complete</option>
                    <option value="missing" selected="@(currentSort == "missing")">Cheapest to Finish</option>
                    <option value="value" selected="@(currentSort == "value")">Highest Deck Value</option>
                    <option value="name" selected="@(currentSort == "name")">Name</option>
                </select>
            </div>

            <div class="col-md-4 col-lg-3">
                <select name="status" class="form-select">
                    <option value="" selected="@(string.IsNullOrWhiteSpace(currentStatus))">All Statuses</option>
                    <option value="Buildable" selected="@(currentStatus == "Buildable")">Buildable</option>
                    <option value="NearlyComplete" selected="@(currentStatus == "NearlyComplete")">Nearly Complete</option>
                    <option value="NeedsWork" selected="@(currentStatus == "NeedsWork")">Needs Work</option>
                </select>
            </div>

            <div class="col-auto">
                <button type="submit" class="btn btn-outline-primary app-btn-utility">Apply</button>
            </div>

            <div class="col-auto">
                <a asp-action="Index" class="btn btn-outline-secondary app-btn-utility">Reset</a>
            </div>
        </form>
    </div>
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <div class="empty-state-title">No decks found</div>
        <p class="empty-state-text">
            No decks match the current filters.
        </p>
    </div>
}
else
{
    <div class="section-card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>@totalDecks deck@(totalDecks == 1 ? "" : "s")</span>
            <span class="text-muted small">Sorted and filtered from your deck collection</span>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive table-wrap">
                <table class="table table-hover align-middle app-table mb-0 deck-index-table">
                    <thead>
                        <tr>
                            <th>Deck</th>
                            <th>Owned</th>
                            <th style="min-width: 190px;">Completion</th>
                            <th>Missing</th>
                            <th>Missing Value</th>
                            <th>Total Deck Cost</th>
                            <th>Status</th>
                            <th style="width: 120px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var deck in Model)
                    {
                        <tr>
                            <td class="deck-summary-cell">
                                <div class="deck-name">@deck.DeckName</div>

                                @if (!string.IsNullOrWhiteSpace(deck.Theme))
                                {
                                    <div class="deck-theme">@deck.Theme</div>
                                }

                                <div class="deck-colors">
                                    Colors:
                                    @if (string.IsNullOrWhiteSpace(deck.ColorIdentity))
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                    else
                                    {
                                        <span class="card-color-identity">@deck.ColorIdentity</span>
                                    }
                                </div>
                            </td>

                            <td>
                                <span class="fw-semibold">@deck.TotalOwned / @deck.TotalRequired</span>
                            </td>

                            <td>
                                <div class="fw-semibold mb-1">@deck.CompletionPercent%</div>
                                <div class="progress deck-progress" role="progressbar"
                                     aria-valuenow="@deck.CompletionPercent"
                                     aria-valuemin="0"
                                     aria-valuemax="100">
                                    <div class="progress-bar deck-progress-bar"
                                         style="width: @deck.CompletionPercent%;">
                                    </div>
                                </div>
                            </td>

                            <td>@deck.MissingCopies</td>
                            <td>@deck.MissingValue.ToString("C")</td>
                            <td>@deck.TotalDeckValue.ToString("C")</td>

                            <td>
                                @if (deck.Status == "Buildable")
                                {
                                    <span class="deck-status-badge status-buildable">Buildable</span>
                                }
                                else if (deck.Status == "Nearly Complete" || deck.Status == "NearlyComplete")
                                {
                                    <span class="deck-status-badge status-nearly">Nearly Complete</span>
                                }
                                else
                                {
                                    <span class="deck-status-badge status-needswork">Needs Work</span>
                                }
                            </td>

                            <td>
                                <div class="d-grid gap-2 deck-action-stack">
                                    <a asp-action="Details"
                                       asp-route-id="@deck.DeckId"
                                       class="btn btn-sm btn-outline-primary">
                                        Open
                                    </a>

                                    <a asp-action="Delete"
                                       asp-route-id="@deck.DeckId"
                                       class="btn btn-sm btn-outline-danger">
                                        Delete
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}