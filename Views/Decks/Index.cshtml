@model IEnumerable<MTGDeckBuilder.Models.ViewModels.DeckBuildabilityViewModel>

@{
    var currentSort = ViewBag.CurrentSort as string;
    var currentStatus = ViewBag.CurrentStatus as string;

    var totalDecks = Model.Count();
    var buildableDecks = Model.Count(d => d.Status == "Buildable");
    var avgCompletion = totalDecks == 0 ? 0 : (int)Math.Round(Model.Average(d => d.CompletionPercent));
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-2">
    <div>
        <h1 class="mb-1">Decks</h1>
        <div class="text-muted">
            Track completion, cost, and buildability across your deck collection.
        </div>
    </div>

    <div>
        <a class="btn btn-primary" asp-action="Create">Create New Deck</a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Total Decks</div>
                <div class="fs-4 fw-bold">@totalDecks</div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Buildable Decks</div>
                <div class="fs-4 fw-bold">@buildableDecks</div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Average Completion</div>
                <div class="fs-4 fw-bold">@avgCompletion%</div>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-center">
            <div class="col-md-3">
                <select name="sort" class="form-select">
                    <option value="" selected="@(string.IsNullOrWhiteSpace(currentSort))">Most Complete</option>
                    <option value="missing" selected="@(currentSort == "missing")">Cheapest to Finish</option>
                    <option value="value" selected="@(currentSort == "value")">Highest Deck Value</option>
                    <option value="name" selected="@(currentSort == "name")">Name</option>
                </select>
            </div>

            <div class="col-md-3">
                <select name="status" class="form-select">
                    <option value="" selected="@(string.IsNullOrWhiteSpace(currentStatus))">All Statuses</option>
                    <option value="Buildable" selected="@(currentStatus == "Buildable")">Buildable</option>
                    <option value="NearlyComplete" selected="@(currentStatus == "NearlyComplete")">Nearly Complete</option>
                    <option value="NeedsWork" selected="@(currentStatus == "NeedsWork")">Needs Work</option>
                </select>
            </div>

            <div class="col-auto">
                <button type="submit" class="btn btn-outline-primary">Apply</button>
            </div>

            <div class="col-auto">
                <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
            </div>
        </form>
    </div>
</div>

@if (!Model.Any())
{
    <div class="card shadow-sm">
        <div class="card-body">
            <div class="fw-semibold mb-1">No decks found</div>
            <div class="text-muted">
                No decks match the current filters.
            </div>
        </div>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-header bg-white fw-semibold">
            @totalDecks deck@(totalDecks == 1 ? "" : "s")
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Deck</th>
                            <th>Owned</th>
                            <th style="min-width: 180px;">Completion</th>
                            <th>Missing</th>
                            <th>Missing Value</th>
                            <th>Total Deck Cost</th>
                            <th>Status</th>
                            <th style="width: 100px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var deck in Model)
                    {
                        <tr>
                            <td>
                                <div class="fw-bold">@deck.DeckName</div>

                                @if (!string.IsNullOrWhiteSpace(deck.Theme))
                                {
                                    <div class="text-muted small">@deck.Theme</div>
                                }

                                <div class="small text-muted">
                                    Colors: @(string.IsNullOrWhiteSpace(deck.ColorIdentity) ? "-" : deck.ColorIdentity)
                                </div>
                            </td>

                            <td>
                                <span class="fw-semibold">@deck.TotalOwned / @deck.TotalRequired</span>
                            </td>

                            <td>
                                <div class="fw-semibold mb-1">@deck.CompletionPercent%</div>
                                <div class="progress" style="height: 10px;">
                                    <div class="progress-bar"
                                         role="progressbar"
                                         style="width: @deck.CompletionPercent%;"
                                         aria-valuenow="@deck.CompletionPercent"
                                         aria-valuemin="0"
                                         aria-valuemax="100">
                                    </div>
                                </div>
                            </td>

                            <td>@deck.MissingCopies</td>
                            <td>@deck.MissingValue.ToString("C")</td>
                            <td>@deck.TotalDeckValue.ToString("C")</td>

                            <td>
                                @if (deck.Status == "Buildable")
                                {
                                    <span class="badge bg-success">Buildable</span>
                                }
                                else if (deck.Status == "Nearly Complete" || deck.Status == "NearlyComplete")
                                {
                                    <span class="badge bg-warning text-dark">Nearly Complete</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Needs Work</span>
                                }
                            </td>

                            <td style="width: 150px;">
                                <div class="d-grid gap-2">
                                    <a asp-action="Details"
                                    asp-route-id="@deck.DeckId"
                                    class="btn btn-sm btn-outline-primary">
                                        Open
                                    </a>

                                    <a asp-action="Delete"
                                    asp-route-id="@deck.DeckId"
                                    class="btn btn-sm btn-outline-danger">
                                        Delete
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}