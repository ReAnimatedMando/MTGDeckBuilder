@model MTGDeckBuilder.Models.Deck
@using MTGDeckBuilder.Models

@{
    var results = ViewBag.SearchResults as List<Card>;
    string? q = ViewBag.Query as string;
    int totalCards = Model.DeckCards?.Sum(dc => dc.Quantity) ?? 0;

    int creatures = Model.DeckCards? 
        .Where(dc => dc.Card != null && !string.IsNullOrEmpty(dc.Card.TypeLine) && dc.Card.TypeLine.Contains("Creature"))
    .Sum(dc => dc.Quantity) ?? 0;

    int instantsSorceries = Model.DeckCards? 
        .Where(dc => dc.Card != null && !string.IsNullOrEmpty(dc.Card.TypeLine) && (dc.Card.TypeLine.Contains("Instant") || dc.Card.TypeLine.Contains("Sorcery")))
    .Sum(dc => dc.Quantity) ?? 0;

    int artifacts = Model.DeckCards?
        .Where(dc => dc.Card != null && !string.IsNullOrEmpty(dc.Card.TypeLine) && dc.Card.TypeLine.Contains("Artifact") && !dc.Card.TypeLine.Contains("Creature"))
    .Sum(dc => dc.Quantity) ?? 0;

    int enchantments = Model.DeckCards?
        .Where(dc => dc.Card != null && !string.IsNullOrEmpty(dc.Card.TypeLine) && dc.Card.TypeLine.Contains("Enchantment") && !dc.Card.TypeLine.Contains("Creature"))
    .Sum(dc => dc.Quantity) ?? 0;

    int planeswalkers = Model.DeckCards?
        .Where(dc => dc.Card != null && !string.IsNullOrEmpty(dc.Card.TypeLine) && dc.Card.TypeLine.Contains("Planeswalker"))
    .Sum(dc => dc.Quantity) ?? 0;

    int lands = Model.DeckCards?
        .Where(dc => dc.Card != null && !string.IsNullOrEmpty(dc.Card.TypeLine) && dc.Card.TypeLine.Contains("Land"))
    .Sum(dc => dc.Quantity) ?? 0;

    var creaturesList = Model.DeckCards?
        .Where(dc => dc.Card != null && !string.IsNullOrEmpty(dc.Card.TypeLine) && dc.Card.TypeLine.Contains("Creature"))
        .OrderBy(dc => dc.Card!.Name)
        .ToList() ?? new List<DeckCard>();
    
    var instantsSorceriesList = Model.DeckCards?
        .Where(dc => dc.Card != null && !string.IsNullOrEmpty(dc.Card.TypeLine) && (dc.Card.TypeLine.Contains("Instant") || dc.Card.TypeLine.Contains("Sorcery")))
        .OrderBy(dc => dc.Card!.Name)
        .ToList() ?? new List<DeckCard>();

    var artifactsList = Model.DeckCards?
        .Where(dc => dc.Card != null && !string.IsNullOrEmpty(dc.Card.TypeLine) && dc.Card.TypeLine.Contains("Artifact") && !dc.Card.TypeLine.Contains("Creature"))
        .OrderBy(dc => dc.Card!.Name)
        .ToList() ?? new List<DeckCard>();

    var enchantmentsList = Model.DeckCards?
        .Where(dc => dc.Card != null && !string.IsNullOrEmpty(dc.Card.TypeLine) && dc.Card.TypeLine.Contains("Enchantment") && !dc.Card.TypeLine.Contains("Creature"))
        .OrderBy(dc => dc.Card!.Name)
        .ToList() ?? new List<DeckCard>();

    var planeswalkersList = Model.DeckCards?
        .Where(dc => dc.Card != null && !string.IsNullOrEmpty(dc.Card.TypeLine) && dc.Card.TypeLine.Contains("Planeswalker"))
        .OrderBy(dc => dc.Card!.Name)
        .ToList() ?? new List<DeckCard>();

    var landsList = Model.DeckCards?
        .Where(dc => dc.Card != null && !string.IsNullOrEmpty(dc.Card.TypeLine) && dc.Card.TypeLine.Contains("Land"))
        .OrderBy(dc => dc.Card!.Name)
        .ToList() ?? new List<DeckCard>();

    var otherList = Model.DeckCards?
        .Where(dc => dc.Card != null && !string.IsNullOrEmpty(dc.Card.TypeLine) && 
            !dc.Card.TypeLine.Contains("Creature") && 
            !dc.Card.TypeLine.Contains("Instant") && 
            !dc.Card.TypeLine.Contains("Sorcery") && 
            !dc.Card.TypeLine.Contains("Artifact") && 
            !dc.Card.TypeLine.Contains("Enchantment") && 
            !dc.Card.TypeLine.Contains("Planeswalker") && 
            !dc.Card.TypeLine.Contains("Land"))
        .OrderBy(dc => dc.Card!.Name)
        .ToList() ?? new List<DeckCard>();

    string deckValidationMessage;
    string deckValidationClass;

    if (totalCards < 60)
    {
        deckValidationMessage = $"Deck is too small ({totalCards} cards). Minimum is 60.";
        deckValidationClass = "alert alert-warning";
    }
    else if (totalCards > 100)
    {
        deckValidationMessage = $"Deck is too large ({totalCards} cards). Maximum is 100.";
        deckValidationClass = "alert alert-danger";
    }
    else 
    {
        deckValidationMessage = $"Deck size is valid ({totalCards} cards).";
        deckValidationClass = "alert alert-success";
    }
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<h1>@Model.Name</h1>

<p>
    <strong>Theme:</strong> @Model.Theme<br />
    <strong>Color Identity:</strong> @Model.ColorIdentity<br />
    <strong>Total Cards:</strong> @totalCards
</p>

<div class="card mb-3" style="max-width: 420px;">
    <div class="card-header">
        <strong>Deck Stats</strong>
    </div>
    <div class="card-body">
        <p class="mb-1"><strong>Total Cards:</strong> @totalCards</p>
        <p class="mb-1"><strong>Creatures:</strong> @creatures</p>
        <p class="mb-1"><strong>Instants/Sorceries:</strong> @instantsSorceries</p>
        <p class="mb-1"><strong>Artifacts:</strong> @artifacts</p>
        <p class="mb-1"><strong>Enchantments:</strong> @enchantments</p>
        <p class="mb-1"><strong>Planeswalkers:</strong> @planeswalkers</p>
        <p class="mb-1"><strong>Lands:</strong> @lands</p>
    </div>
</div>

<div class="@deckValidationClass">
    @deckValidationMessage
</div>

<hr />

<h2>Card List</h2>

@if (Model.DeckCards == null || !Model.DeckCards.Any())
{
    <p>No cards yet. Search below and add some.</p>
}
else
{
    @if (creaturesList.Any())
    {
        @await Html.PartialAsync("_DeckCardSection", creaturesList, new ViewDataDictionary(ViewData)
        {
            ["SectionTitle"] = "Creatures",
            ["DeckId"] = Model.Id
        })
    }

    @if (instantsSorceriesList.Any())
    {
        @await Html.PartialAsync("_DeckCardSection", instantsSorceriesList, new ViewDataDictionary(ViewData)
        {
            ["SectionTitle"] = "Instants / Sorceries",
            ["DeckId"] = Model.Id
        })
    }

    @if (artifactsList.Any())
    {
        @await Html.PartialAsync("_DeckCardSection", artifactsList, new ViewDataDictionary(ViewData)
        {
            ["SectionTitle"] = "Artifacts",
            ["DeckId"] = Model.Id
        })
    }

    @if (enchantmentsList.Any())
    {
        @await Html.PartialAsync("_DeckCardSection", enchantmentsList, new ViewDataDictionary(ViewData)
        {
            ["SectionTitle"] = "Enchantments",
            ["DeckId"] = Model.Id
        })
    }

    @if (planeswalkersList.Any())
    {
        @await Html.PartialAsync("_DeckCardSection", planeswalkersList, new ViewDataDictionary(ViewData)
        {
            ["SectionTitle"] = "Planeswalkers",
            ["DeckId"] = Model.Id
        })
    }

     @if (landsList.Any())
    {
        @await Html.PartialAsync("_DeckCardSection", landsList, new ViewDataDictionary(ViewData)
        {
            ["SectionTitle"] = "Lands",
            ["DeckId"] = Model.Id
        })
    }
    @if (otherList.Any())
    {
        @await Html.PartialAsync("_DeckCardSection", otherList, new ViewDataDictionary(ViewData)
        {
            ["SectionTitle"] = "Other",
            ["DeckId"] = Model.Id
        })
    }
}
            <thead>
                <tr>
                    <th style="width: 120px;">Qty</th>
                    <th>Card</th>
                    <th>Type</th>
                    <th style="width: 160px;"></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var dc in otherList)
            {
                <tr>
                    <td>
                        <form asp-action="SetQuantity" method="post" class="d-flex gap-2">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="deckId" value="@Model.Id" />
                            <input type="hidden" name="cardId" value="@dc.CardId" />
                            <input type="number" name="quantity" value="@dc.Quantity" min="0" class="form-control" style="max-width:90px;" />
                            <button class="btn btn-sm btn-outline-primary" type="submit">Set</button>
                        </form>
                    </td>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            @if (!string.IsNullOrEmpty(dc.Card?.ImageUrl))
                            {
                                <img src="@dc.Card.ImageUrl" alt="@dc.Card.Name" style="height:40px; border-radius:4px;" />
                            }
                            <a asp-controller="Cards" asp-action="Details" asp-route-id="@dc.CardId">@dc.Card?.Name</a>
                        </div>
                    </td>
                    <td>@dc.Card?.TypeLine</td>
                    <td>
                        <form asp-action="RemoveCard" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="deckId" value="@Model.Id" />
                            <input type="hidden" name="cardId" value="@dc.CardId" />
                            <button class="btn btn-sm btn-outline-danger" type="submit">Remove</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }
}



<hr />

<h2>Add Cards</h2>

<form method="get" class="d-flex gap-2 mb-3">
    <input type="hidden" name="id" value="@Model.Id" />
    <input type="text" name="q" value="@q" class="form-control" placeholder="Search card name (e.g. Lightning Bolt)" />
    <button type="submit" class="btn btn-primary">Search</button>
</form>

@if (results != null)
{
    if (!results.Any())
    {
        <p>No results.</p>
    }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Card</th>
                    <th>Type</th>
                    <th style="width: 220px;"></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var c in results)
            {
                <tr>
                    <td>
                        <a asp-controller="Cards" asp-action="Details" asp-route-id="@c.Id">@c.Name</a>
                    </td>
                    <td>@c.TypeLine</td>
                    <td>
                        <form asp-action="AddCard" method="post" class="d-flex gap-2">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="deckId" value="@Model.Id" />
                            <input type="hidden" name="cardId" value="@c.Id" />
                            <input type="number" name="quantity" value="1" min="1" class="form-control" style="max-width:90px;" />
                            <button class="btn btn-sm btn-success" type="submit">Add</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }
}

<p>
    <a asp-action="Index">Back to Decks</a>
</p>