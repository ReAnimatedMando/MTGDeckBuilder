@model MTGDeckBuilder.Models.Deck
@using MTGDeckBuilder.Models

@{
    var missingCards = ViewBag.MissingCards as List<MissingCardInfo> ?? new List<MissingCardInfo>();
}

@{
    var mainDeckCards = Model.DeckCards?
        .Where(dc => !dc.IsSideboard)
        .ToList() ?? new List<DeckCard>();

    var sideboardCards = Model.DeckCards?
        .Where(dc => dc.IsSideboard)
        .ToList() ?? new List<DeckCard>();
}

@{
    var results = ViewBag.SearchResults as List<Card>;
    string? q = ViewBag.Query as string;
    int totalCards = mainDeckCards.Sum(dc => dc.Quantity);
    int sideboardTotal = sideboardCards.Sum(dc => dc.Quantity);

    int creatures = mainDeckCards? 
        .Where(dc => dc.Card != null && !string.IsNullOrEmpty(dc.Card.TypeLine) && dc.Card.TypeLine.Contains("Creature"))
        .Sum(dc => dc.Quantity) ?? 0;

    int instantsSorceries = mainDeckCards? 
        .Where(dc => dc.Card != null && !string.IsNullOrEmpty(dc.Card.TypeLine) && (dc.Card.TypeLine.Contains("Instant") || dc.Card.TypeLine.Contains("Sorcery")))
        .Sum(dc => dc.Quantity) ?? 0;

    int artifacts = mainDeckCards?
        .Where(dc => dc.Card != null && !string.IsNullOrEmpty(dc.Card.TypeLine) && dc.Card.TypeLine.Contains("Artifact") && !dc.Card.TypeLine.Contains("Creature"))
        .Sum(dc => dc.Quantity) ?? 0;

    int enchantments = mainDeckCards?
        .Where(dc => dc.Card != null && !string.IsNullOrEmpty(dc.Card.TypeLine) && dc.Card.TypeLine.Contains("Enchantment") && !dc.Card.TypeLine.Contains("Creature"))
        .Sum(dc => dc.Quantity) ?? 0;

    int planeswalkers = mainDeckCards?
        .Where(dc => dc.Card != null && !string.IsNullOrEmpty(dc.Card.TypeLine) && dc.Card.TypeLine.Contains("Planeswalker"))
        .Sum(dc => dc.Quantity) ?? 0;

    int lands = mainDeckCards?
        .Where(dc => dc.Card != null && !string.IsNullOrEmpty(dc.Card.TypeLine) && dc.Card.TypeLine.Contains("Land"))
        .Sum(dc => dc.Quantity) ?? 0;

    int spells = totalCards - lands;

    var creaturesList = mainDeckCards?
        .Where(dc => dc.Card != null && !string.IsNullOrEmpty(dc.Card.TypeLine) && dc.Card.TypeLine.Contains("Creature"))
        .OrderBy(dc => dc.Card!.Name)
        .ToList() ?? new List<DeckCard>();
    
    var instantsSorceriesList = mainDeckCards?
        .Where(dc => dc.Card != null && !string.IsNullOrEmpty(dc.Card.TypeLine) && (dc.Card.TypeLine.Contains("Instant") || dc.Card.TypeLine.Contains("Sorcery")))
        .OrderBy(dc => dc.Card!.Name)
        .ToList() ?? new List<DeckCard>();

    var artifactsList = mainDeckCards?
        .Where(dc => dc.Card != null && !string.IsNullOrEmpty(dc.Card.TypeLine) && dc.Card.TypeLine.Contains("Artifact") && !dc.Card.TypeLine.Contains("Creature"))
        .OrderBy(dc => dc.Card!.Name)
        .ToList() ?? new List<DeckCard>();

    var enchantmentsList = mainDeckCards?
        .Where(dc => dc.Card != null && !string.IsNullOrEmpty(dc.Card.TypeLine) && dc.Card.TypeLine.Contains("Enchantment") && !dc.Card.TypeLine.Contains("Creature"))
        .OrderBy(dc => dc.Card!.Name)
        .ToList() ?? new List<DeckCard>();

    var planeswalkersList = mainDeckCards?
        .Where(dc => dc.Card != null && !string.IsNullOrEmpty(dc.Card.TypeLine) && dc.Card.TypeLine.Contains("Planeswalker"))
        .OrderBy(dc => dc.Card!.Name)
        .ToList() ?? new List<DeckCard>();

    var landsList = mainDeckCards?
        .Where(dc => dc.Card != null && !string.IsNullOrEmpty(dc.Card.TypeLine) && dc.Card.TypeLine.Contains("Land"))
        .OrderBy(dc => dc.Card!.Name)
        .ToList() ?? new List<DeckCard>();

    var otherList = mainDeckCards?
        .Where(dc => dc.Card != null && !string.IsNullOrEmpty(dc.Card.TypeLine) && 
            !dc.Card.TypeLine.Contains("Creature") && 
            !dc.Card.TypeLine.Contains("Instant") && 
            !dc.Card.TypeLine.Contains("Sorcery") && 
            !dc.Card.TypeLine.Contains("Artifact") && 
            !dc.Card.TypeLine.Contains("Enchantment") && 
            !dc.Card.TypeLine.Contains("Planeswalker") && 
            !dc.Card.TypeLine.Contains("Land"))
        .OrderBy(dc => dc.Card!.Name)
        .ToList() ?? new List<DeckCard>();

    var sideboardList = sideboardCards
        .OrderBy(dc => dc.Card!.Name)
        .ToList();

    string deckValidationMessage;
    string deckValidationClass;

    if (totalCards < 60)
    {
        deckValidationMessage = $"Deck is too small ({totalCards} cards). Minimum is 60.";
        deckValidationClass = "alert alert-warning";
    }
    else if (totalCards > 100)
    {
        deckValidationMessage = $"Deck is too large ({totalCards} cards). Maximum is 100.";
        deckValidationClass = "alert alert-danger";
    }
    else 
    {
        deckValidationMessage = $"Deck size is valid ({totalCards} cards).";
        deckValidationClass = "alert alert-success";
    }
}



@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-start gap-3 mb-4">
    <div>
        <h1 class="mb-1">@Model.Name</h1>
        <div class="text-muted">
            @(string.IsNullOrWhiteSpace(Model.Theme) ? "No theme specified" : Model.Theme)
        </div>
        <div class="mt-2 small text-muted">
            Color Identity: @(string.IsNullOrWhiteSpace(Model.ColorIdentity) ? "-" : Model.ColorIdentity.Replace(",", ", "))
            <span class="mx-2">•</span>
            Main Deck: @totalCards
            <span class="mx-2">•</span>
            Sideboard: @sideboardTotal
        </div>
    </div>

    <div class="d-flex flex-wrap gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-warning">Edit Deck</a>
        <a asp-action="Export" asp-route-id="@Model.Id" class="btn btn-outline-primary">Export Decklist</a>
        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">Delete Deck</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Back to Decks</a>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-12 col-lg-6">
        <div class="card h-100">
            <div class="card-header bg-white fw-semibold">
                <strong>Deck Stats</strong>
            </div>
            <div class="card-body">
                <p class="mb-1"><strong>Total Cards:</strong> @totalCards</p>
                <p class="mb-1"><strong>Creatures:</strong> @creatures</p>
                <p class="mb-1"><strong>Instants/Sorceries:</strong> @instantsSorceries</p>
                <p class="mb-1"><strong>Artifacts:</strong> @artifacts</p>
                <p class="mb-1"><strong>Enchantments:</strong> @enchantments</p>
                <p class="mb-1"><strong>Planeswalkers:</strong> @planeswalkers</p>
                <p class="mb-1"><strong>Lands:</strong> @lands</p>
                <p class="mb-1"><strong>Spells:</strong> @spells</p>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-6">
        <div class="card h-100">
            <div class="card-header bg-white fw-semibold">
                <strong>Deck Completion</strong>
            </div>
            <div class="card-body">
                <p class="mb-1"><strong>Owned Copies:</strong> @ViewBag.OwnedCopies / @ViewBag.RequiredCopies</p>
                <p class="mb-2"><strong>Completion:</strong> @ViewBag.CompletionPercent%</p>

                <div class="progress mb-3" style="height: 24px;">
                    <div class="progress-bar bg-success"
                         role="progressbar"
                         style="width:@ViewBag.CompletionPercent%"
                         aria-valuenow="@ViewBag.CompletionPercent"
                         aria-valuemin="0"
                         aria-valuemax="100">
                        @ViewBag.CompletionPercent%
                    </div>
                </div>

                <p class="mb-1"><strong>Missing Unique Cards:</strong> @ViewBag.MissingUniqueCards</p>
                <p class="mb-1"><strong>Missing Total Copies:</strong> @ViewBag.MissingTotalCopies</p>

                <hr />

                <p class="mb-1"><strong>Main Deck Cost:</strong> @(((decimal)ViewBag.MainDeckCost).ToString("C"))</p>
                <p class="mb-1"><strong>Sideboard Cost:</strong> @(((decimal)ViewBag.SideboardCost).ToString("C"))</p>
                <p class="mb-1"><strong>Total Deck Cost:</strong> @(((decimal)ViewBag.TotalDeckCost).ToString("C"))</p>
                <p class="mb-1"><strong>Owned Value:</strong> @(((decimal)ViewBag.OwnedValue).ToString("C"))</p>
                <p class="mb-0"><strong>Missing Value:</strong> @(((decimal)ViewBag.MissingValue).ToString("C"))</p>
            </div>
        </div>
    </div>
</div>

<hr class="my-5" />

<div class="mb-4">
    <button class="btn btn-outline-danger d-flex align-items-center gap-2" type="button" data-bs-toggle="collapse" data-bs-target="#missingCardsCollapse" aria-expanded="true" aria-controls="missingCardsCollapse">
        <span id="missingCardsChevron">▼</span>
        Missing Cards (@ViewBag.MissingTotalCopies copies across @ViewBag.MissingUniqueCards cards)
    </button>
</div>

<div class="collapse" id="missingCardsCollapse">
    @if (missingCards.Any())
    {
        <div class="card mb-4">
            <div class="card-header bg-white fw-semibold">
                <strong>Missing Cards</strong>
            </div>
            <div class="card-body">
                <div class="list-group list-group-flush">
                    @foreach (var missing in missingCards.OrderByDescending(m => m.MissingQuantity).ThenBy(m => m.CardName))
                    {
                        <div class="list-group-item px-0">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <strong>
                                        <a asp-controller="Cards"
                                           asp-action="Details"
                                           asp-route-id="@missing.CardId"
                                           class="text-decoration-none">
                                            @missing.CardName
                                        </a>
                                    </strong>
                                </div>
                                <div class="text-danger fw-bold">
                                    Missing @missing.MissingQuantity
                                </div>
                            </div>
                            <div class="small text-muted">
                                Owned: @missing.OwnedQuantity / Required: @missing.RequiredQuantity
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-success mb-4">
            <strong>Complete!</strong> You own every card in the main deck.
        </div>
    }
</div>

<hr class="my-5" />

<div class="@deckValidationClass">
    @deckValidationMessage
</div>

<hr class="my-5" />

<h2 class="mb-3">Add Cards</h2>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form asp-action="Details" asp-controller="Decks" method="get" class="d-flex gap-2 flex-wrap">
            <input type="hidden" name="id" value="@Model.Id" />
            <input type="text"
                   name="q"
                   value="@q"
                   class="form-control"
                   placeholder="Search card name (e.g. Lightning Bolt)" />
            <button type="submit" class="btn btn-primary">Search</button>
            @if (!string.IsNullOrWhiteSpace(q))
            {
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Clear</a>
            }
        </form>
    </div>
</div>

@if (results != null)
{
    if (!results.Any())
    {
        <div class="card shadow-sm mb-4">
            No cards matched your search.
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-3">
            @foreach (var c in results)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <div class="d-flex gap-3">
                                <div style="width: 72px; flex-shrink: 0;">
                                    @if (!string.IsNullOrWhiteSpace(c.ImageUrl))
                                    {
                                        <img src="@c.ImageUrl"
                                             alt="@c.Name"
                                             class="img-fluid rounded card-preview-trigger"
                                             data-image-url="@c.ImageUrl"
                                             data-card-name="@c.Name"
                                             style="width: 72px; cursor: pointer;" />
                                    }
                                    else
                                    {
                                        <div class="border rounded d-flex align-items-center justify-content-center text-muted small"
                                             style="width:72px; height:100px;">
                                            No Image
                                        </div>
                                    }
                                </div>

                                <div class="flex-grow-1">
                                    <div class="fw-bold">
                                        <a asp-controller="Cards" asp-action="Details" asp-route-id="@c.Id" class="text-decoration-none card-preview-trigger" data-image-url="@c.ImageUrl" data-card-name="@c.Name">@c.Name</a>
                                    </div>

                                    @if (!string.IsNullOrWhiteSpace(c.ManaCost))
                                    {
                                        <div class="text-muted small mb-1">@c.ManaCost</div>
                                    }

                                    <div class="small mb-3">@c.TypeLine</div>

                                    <form asp-action="AddCard" method="post" class="d-flex gap-2 align-items-center flex-wrap">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="deckId" value="@Model.Id" />
                                        <input type="hidden" name="cardId" value="@c.Id" />
                                        <input type="number" name="quantity" value="1" min="1" class="form-control form-control-sm" style="max-width: 72px;" />
                                        <button class="btn btn-sm btn-success" type="submit" name="isSideboard" value="false">+ Main</button>

                                        <button class="btn btn-sm btn-outline-secondary" type="submit" name="isSideboard" value="true">+ Sideboard</button>
                                    </form>
                                    <form asp-action="AddToOwned" method="post" class="mt-2 d-flex gap-2 align-items-center">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="deckId" value="@Model.Id"/>
                                        <input type="hidden" name="cardId" value="@c.Id" />
                                        <input type="number" name="quantity" value="1" min="1" class="form-control form-control-sm" style="max-width: 72px;" />
                                        <button class="btn btn-sm btn-outline-warning" type="submit">+ Owned</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}

<hr class="my-5" />

<h2 class="mb-3">Card List</h2>

@if (Model.DeckCards == null || !Model.DeckCards.Any())
{
    <div class="card shadow-sm mb-4">
        <div class="card-body text-muted">
        No cards in this deck yet. Search above to add some.
        </div>
    </div>
}
else
{
    @if (creaturesList.Any())
    {
        @await Html.PartialAsync("_DeckCardSection", creaturesList, new ViewDataDictionary(ViewData)
        {
            ["SectionTitle"] = "Creatures",
            ["DeckId"] = Model.Id,
            ["IsSideboard"] = false
        })
    }

    @if (instantsSorceriesList.Any())
    {
        @await Html.PartialAsync("_DeckCardSection", instantsSorceriesList, new ViewDataDictionary(ViewData)
        {
            ["SectionTitle"] = "Instants / Sorceries",
            ["DeckId"] = Model.Id,
            ["IsSideboard"] = false
        })
    }

    @if (artifactsList.Any())
    {
        @await Html.PartialAsync("_DeckCardSection", artifactsList, new ViewDataDictionary(ViewData)
        {
            ["SectionTitle"] = "Artifacts",
            ["DeckId"] = Model.Id,
            ["IsSideboard"] = false
        })
    }

    @if (enchantmentsList.Any())
    {
        @await Html.PartialAsync("_DeckCardSection", enchantmentsList, new ViewDataDictionary(ViewData)
        {
            ["SectionTitle"] = "Enchantments",
            ["DeckId"] = Model.Id,
            ["IsSideboard"] = false
        })
    }

    @if (planeswalkersList.Any())
    {
        @await Html.PartialAsync("_DeckCardSection", planeswalkersList, new ViewDataDictionary(ViewData)
        {
            ["SectionTitle"] = "Planeswalkers",
            ["DeckId"] = Model.Id,
            ["IsSideboard"] = false
        })
    }

     @if (landsList.Any())
    {
        @await Html.PartialAsync("_DeckCardSection", landsList, new ViewDataDictionary(ViewData)
        {
            ["SectionTitle"] = "Lands",
            ["DeckId"] = Model.Id,
            ["IsSideboard"] = false
        })
    }
    @if (otherList.Any())
    {
        @await Html.PartialAsync("_DeckCardSection", otherList, new ViewDataDictionary(ViewData)
        {
            ["SectionTitle"] = "Other",
            ["DeckId"] = Model.Id,
            ["IsSideboard"] = false
        })
    }
}

<hr class="my-5" />

<h2 class="mb-3">Sideboard</h2>

@if (!sideboardList.Any())
{
    <div class="card shadow-sm mb-4">
        No sideboard cards yet.
    </div>
}
else
{
    @await Html.PartialAsync("_DeckCardSection", sideboardList, new ViewDataDictionary(ViewData)
    {
        ["SectionTitle"] = "Sideboard",
        ["DeckId"] = Model.Id,
        ["IsSideboard"] = true
    })
}

<hr class="my-5" />

<h2 class="mb-3">Deck Analysis</h2>

@{
    var curveData = ViewBag.ManaCurveData as List<int> ?? new List<int>();
    var labels = new List<string> { "0", "1", "2", "3", "4", "5", "6", "7+" };
    var maxValue = curveData.Any() ? curveData.Max() : 1;

    if (maxValue == 0)
    {
        maxValue = 1;
    }

    var colorPieData = ViewBag.ColorPieData as Dictionary<string, int> ?? new Dictionary<string, int>();
    var colorLabels = new Dictionary<string, string>
    {
        ["W"] = "White",
        ["U"] = "Blue",
        ["B"] = "Black",
        ["R"] = "Red",
        ["G"] = "Green"
    };

    var colorClasses = new Dictionary<string, string>
        {
            ["W"] = "bg-light text-dark",
            ["U"] = "bg-primary",
            ["B"] = "bg-dark",
            ["R"] = "bg-danger",
            ["G"] = "bg-success"
        };

    var maxColorValue = colorPieData.Any() ? colorPieData.Values.Max() : 1;

    if (maxColorValue == 0)
    {
        maxColorValue = 1;
    }
}

<div class="row g-4 mb-5">
    <div class="col-12 col-lg-6">
        <h3>Mana Curve Chart</h3>

        <div class="card shadow-sm h-100 p-3">
            <div class="d-flex align-items-end justify-content-between" style="height: 220px;">
                @for (int i = 0; i < curveData.Count; i++)
                {
                    var count = curveData[i];
                    var heightPercent = (int)Math.Round((double)count / maxValue * 100);
                    var minHeight = count > 0 ? "12px" : "0";

                    <div class="text-center" style="width: 52px;">
                        <div class="mb-2 fw-bold">@count</div>

                        <div class="d-flex align-items-end justify-content-center" style="height: 160px;">
                            <div class="bg-primary rounded-top"
                                 style="width: 40px; height:@(heightPercent)%; min-height:@minHeight;">
                            </div>
                        </div>

                        <div class="mt-2">@labels[i]</div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-6">
        <h3>Color Pie Distribution</h3>

        <div class="card shadow-sm h-100 p-3">
            @foreach (var kvp in colorLabels)
            {
                var key = kvp.Key;
                var label = kvp.Value;
                var count = colorPieData.ContainsKey(key) ? colorPieData[key] : 0;
                var widthPercent = (int)Math.Round((double)count / maxColorValue * 100);

                <div class="mb-3">
                    <div class="d-flex justify-content-between">
                        <span><strong>@label (@key)</strong></span>
                        <span>@count</span>
                    </div>

                    <div class="progress" style="height: 24px; border-radius: 8px;">
                        <div class="progress-bar @colorClasses[key]"
                             role="progressbar"
                             style="width:@(widthPercent)%; border-radius: 8px;"
                             aria-valuenow="@count"
                             aria-valuemin="0"
                             aria-valuemax="@maxColorValue">
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<div class="row g-4 mb-5">
    <div class="col-12 col-lg-6">
        <h3>Land vs Spells</h3>

        <div class="card shadow-sm p-3">
            <p class="mb-3"><strong>Lands:</strong> @lands | <strong>Spells:</strong> @spells</p>

            <div style="position: relative; height: 260px; max-width: 260px; margin: 0 auto;">
                <canvas id="landSpellChart"></canvas>
            </div>
        </div>
    </div>
</div>

<hr class="my-5" />

<h2 class="mb-3">Import Deck from URL</h2>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form asp-action="ImportFromUrl" asp-controller="Decks" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="deckId" value="@Model.Id" />

            <div class="input-group">
                <input type="url" name="url" class="form-control" placeholder="Paste Moxfield or Archidekt URL" />
                <button type="submit" class="btn btn-outline-success">Import URL</button>
            </div>
        </form>
    </div>
</div>

<hr class="my-5" />

<h2 class="mb-3">Import Decklist</h2>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form asp-action="ImportDecklist" asp-controller="Decks" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="deckId" value="@Model.Id" />
            <div class="mb-3">
                <label for="decklistText" class="form-label">Paste decklist</label>
                <textarea id="decklistText" name="decklistText" class="form-control" rows="10" placeholder="4 Lightning Bolt&#10;4 Monastery Swiftspear&#10;4 Lava Spike&#10;&#10;Sideboard&#10;2 Smash to Smithereens&#10;2 Roiling Vortex"></textarea>
            </div>

            <button type="submit" class="btn btn-primary">
                Import Decklist
            </button>
        </form>
    </div>
</div>

<div id="cardPreviewPopup" class="card-preview-popup d-none">
    <img id="cardPreviewImage" src="" alt="Card Preview" />
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
    document.addEventListener("DOMContentLoaded", function () {
        const ctx = document.getElementById("landSpellChart");

        if (!ctx) {
            return;
        }

        new Chart(ctx, {
            type: "pie",
            data: {
                labels: ["Lands", "Spells"],
                datasets: [{
                    data: [@lands, @spells],
                    backgroundColor: ["#d4af37", "#6c757d"],
                    borderColor: "#ffffff",
                    borderWidth: 2
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: "top"
                    }
                }
            }
        });
    });
    </script>

    <script>
    document.addEventListener("DOMContentLoaded", function () {
        const collapse = document.getElementById("missingCardsCollapse");
        const chevron = document.getElementById("missingCardsChevron");

        if (!collapse || !chevron) return;

        collapse.addEventListener("show.bs.collapse", function () {
            chevron.textContent = "▼";
        });

        collapse.addEventListener("hide.bs.collapse", function () {
            chevron.textContent = "▶";
        });
    });
    </script>

    <script>
        // Save scroll position before form submits
        document.addEventListener("DOMContentLoaded", function() {
            const forms = document.querySelectorAll("form");

            forms.forEach(form => {
                form.addEventListener("submit", function () {
                    sessionStorage.setItem("scrollPosition", window.scrollY);
                });
            });
        });
    </script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const scrollPosition = sessionStorage.getItem("scrollPosition");

            if (scrollPosition !== null) {
                window.scrollTo(0, parseInt(scrollPosition));
                sessionStorage.removeItem("scrollPosition");
            }
        });
    </script>
}