@model IEnumerable<MTGDeckBuilder.Models.DeckCard>

@{
    var title = ViewData["SectionTitle"] as string ?? "Cards";
    var deckId = (int)(ViewData["DeckId"] ?? 0);
    var isSideboard = (bool)(ViewData["IsSideboard"] ?? false);
    var total = Model.Sum(dc => dc.Quantity);
}

<h3>@title (@total)</h3>

<table class="table align-middle">
    <thead>
        <tr>
            <th style="width: 140px;">Qty</th>
            <th>Card</th>
            <th style="width:150px;">Owned</th>
            <th>Type</th>
            <th style="width: 120px;"></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var dc in Model)
        {
            var owned = dc.Card?.OwnedCards?.Sum(o => o.Quantity) ?? 0;
            var needed = dc.Quantity;
            <tr>
                <td>
                    <form asp-action="SetQuantity" method="post" class="d-flex gap-2">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="deckId" value="@deckId" />
                        <input type="hidden" name="cardId" value="@dc.CardId" />
                        <input type="hidden" name="isSideboard" value="@isSideboard.ToString().ToLower()" />
                        <input type="number" name="quantity" value="@dc.Quantity" min="0" class="form-control" style="max-width: 90px;" />
                        <button class="btn btn-sm btn-outline-primary" type="submit">Set</button>
                    </form>
                </td>

                <td>
                    <div class="d-flex align-items-center gap-2">
                        @if (!string.IsNullOrWhiteSpace(dc.Card?.ImageUrl))
                        {
                            <img src="@dc.Card.ImageUrl"
                                 alt="@dc.Card.Name"
                                 class="img-fluid rounded card-preview-trigger"
                                 data-image-url="@dc.Card.ImageUrl"
                                 data-card-name="@dc.Card.Name"
                                 style="width: 60px; cursor: pointer;" />
                        }
                        else
                        {
                            <div class="text-muted small">No Image</div>
                        }

                        <a asp-controller="Cards"
                           asp-action="Details"
                           asp-route-id="@dc.CardId"
                           class="card-preview-trigger"
                           data-image-url="@dc.Card?.ImageUrl"
                           data-card-name="@dc.Card?.Name">
                            @dc.Card?.Name
                        </a>
                    </div>
                </td>

                <td>
                    @owned / @needed
                    @if (owned >= needed)
                    {
                        <span class="text-success fw-bold">✓</span>
                    }
                </td>

                <td>@dc.Card?.TypeLine</td>

                <td>
                    <form asp-action="RemoveCard" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="deckId" value="@deckId" />
                        <input type="hidden" name="cardId" value="@dc.CardId" />
                        <input  type="hidden" name="isSideboard" value="@isSideboard.ToString().ToLower()" />
                        <button class="btn btn-sm btn-outline-danger" type="submit">Remove</button>
                    </form>

                    <form asp-action="AddToOwned" method="post" class="mt-2 d-flex gap-2 align-items-center">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="deckId" value="@deckId" />
                        <input type="hidden" name="cardId" value="@dc.CardId" />
                        <input type="number" name="quantity" value="1" min="1" class="form-control form-control-sm" style="max-width: 80px;" />
                        <button class="btn btn-sm btn-outline-warning" type="submit">+ Owned</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
