@model IEnumerable<MTGDeckBuilder.Models.DeckCard>

@{
    var title = ViewData["SectionTitle"] as string ?? "Cards";
    var deckId = (int)(ViewData["DeckId"] ?? 0);
    var isSideboard = (bool)(ViewData["IsSideboard"] ?? false);
    var total = Model.Sum(dc => dc.Quantity);
}

<div class="card shadow-sm mb-4">
    <div class="card-header bg-white fw-semibold">
        @title (@total)
    </div>

    @if (!Model.Any())
    {
        <div class="card-body text-muted">
            No cards in this section.
        </div>
    }
    else
    {
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0 deck-card-table">
                    <thead>
                        <tr>
                            <th style="width: 90px;">Qty</th>
                            <th>Card</th>
                            <th class="d-none d-md-table-cell">Type</th>
                            <th style="width: 110px;">Owned</th>
                            <th style="width: 170px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var dc in Model)
                        {
                            var owned = dc.Card?.OwnedCards?.Sum(o => o.Quantity) ?? 0;
                            var needed = dc.Quantity;
                            var isComplete = owned >= needed;

                            <tr>
                                <td>
                                    <form asp-action="SetQuantity" method="post" class="d-flex gap-2 align-items-center">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="deckId" value="@deckId" />
                                        <input type="hidden" name="cardId" value="@dc.CardId" />
                                        <input type="hidden" name="isSideboard" value="@isSideboard.ToString().ToLower()" />
                                        <input type="number"
                                               name="quantity"
                                               value="@dc.Quantity"
                                               min="0"
                                               class="form-control form-control-sm"
                                               style="max-width: 90px;" />
                                        <button class="btn btn-sm btn-outline-primary" type="submit">Set</button>
                                    </form>
                                </td>

                                <td class="card-name-cell">
                                    <div class="d-flex align-items-center gap-2">
                                        @if (!string.IsNullOrWhiteSpace(dc.Card?.ImageUrl))
                                        {
                                            <img src="@dc.Card.ImageUrl"
                                                alt="@dc.Card.Name"
                                                class="img-fluid rounded shadow-sm card-preview-trigger"
                                                data-image-url="@dc.Card.ImageUrl"
                                                data-card-name="@dc.Card.Name"
                                                style="width: 60px; height: auto; cursor: pointer;" />
                                        }
                                        else
                                        {
                                            <div class="text-muted small">No Image</div>
                                        }

                                        <div class="min-w-0">
                                            <a asp-controller="Cards"
                                            asp-action="Details"
                                            asp-route-id="@dc.CardId"
                                            class="fw-semibold text-decoration-none text-break d-inline-block card-preview-trigger"
                                            data-image-url="@dc.Card?.ImageUrl"
                                            data-card-name="@dc.Card?.Name">
                                            @dc.Card?.Name
                                            </a>
                                        </div>
                                    </div>
                                </td>

                                <td class="d-none d-md-table-cell">
                                    @(string.IsNullOrWhiteSpace(dc.Card?.TypeLine) ? "-" : dc.Card.TypeLine)
                                </td>

                                <td>
                                    <div class="owned-summary small">
                                        <div class="fw-semibold">@owned / @needed</div>
                                        @if (isComplete)
                                        {
                                            <div class="text-success">Complete ✓</div>
                                        }
                                        else
                                        {
                                            <div class="text-muted">Missing @(needed - owned)</div>
                                        }
                                    </div>
                                </td>

                                <td class="actions-cell">
                                    <form asp-action="RemoveCard" method="post" class="mb-2">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="deckId" value="@deckId" />
                                        <input type="hidden" name="cardId" value="@dc.CardId" />
                                        <input type="hidden" name="isSideboard" value="@isSideboard.ToString().ToLower()" />
                                        <button class="btn btn-sm btn-outline-danger w-100" type="submit">Remove</button>
                                    </form>

                                    <form asp-action="AddToOwned" method="post" class="d-flex gap-2 align-items-center">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="deckId" value="@deckId" />
                                        <input type="hidden" name="cardId" value="@dc.CardId" />
                                        <input type="number"
                                               name="quantity"
                                               value="1"
                                               min="1"
                                               class="form-control form-control-sm"
                                               style="max-width: 80px;" />
                                        <button class="btn btn-sm btn-outline-warning" type="submit">+ Owned</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
