@model MTGDeckBuilder.Models.Deck

@{
    ViewData["Title"] = "Create Deck";
}

<div class="page-header">
    <div class="page-eyebrow">Deck Workshop</div>
    <h1 class="page-title">Create Deck</h1>
    <p class="page-subtitle">
        Start a new deck with a name, theme, and color identity.
    </p>
</div>

<div class="row">
    <div class="col-lg-8 col-xl-6">
        <div class="section-card">
            <div class="card-header">New Deck</div>
            <div class="card-body">
                <form asp-action="Create" method="post" class="deck-form">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label deck-form-label"></label>
                        <input asp-for="Name" class="form-control deck-form-control" placeholder="Example: Boros Burn" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Theme" class="form-label deck-form-label"></label>
                        <input asp-for="Theme" class="form-control deck-form-control" placeholder="Examples: Burn, Angels, Zombies, Control" />
                        <div class="form-text">Optional theme or archetype for this deck.</div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ColorIdentity" class="form-label deck-form-label"></label>
                        <input asp-for="ColorIdentity" class="form-control deck-form-control" placeholder="W,U,B,R,G" />
                        <div class="form-text">Use comma-separated values like W,U or a single color like G.</div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Description" class="form-label deck-form-label"></label>
                        <textarea asp-for="Description" class="form-control deck-form-control" rows="4"
                                  placeholder="What is this deck trying to do?"></textarea>
                    </div>

                    <div class="d-flex flex-wrap gap-2">
                        <button type="submit" class="btn app-btn-primary">Create Deck</button>
                        <a asp-action="Index" class="btn btn-outline-secondary app-btn-utility">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}