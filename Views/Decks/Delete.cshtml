@model MTGDeckBuilder.Models.Deck

@{
    ViewData["Title"] = "Delete Deck";
}

<h1>Delete Deck</h1>

<div class="alert alert-danger">
    Are you sure you want to delete this deck?
</div>

<div class="card p-3 mb-3">
    <h4>@Model.Name</h4>
    <div>
        <strong>Theme:</strong> @(string.IsNullOrWhiteSpace(Model.Theme) ? "None" : Model.Theme)
    </div>
    <div>
        <strong>Color Identity:</strong> @(string.IsNullOrWhiteSpace(Model.ColorIdentity) ? "-" : Model.ColorIdentity)
    </div>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary">Cancel</a>
</form>